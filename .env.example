# Chatbot Platform Configuration
# Copy this to .env and fill in your values

# API Settings
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8000
CHATBOT_DEBUG=false
CHATBOT_DEFAULT_PROVIDER=ollama
CHATBOT_DEFAULT_MODEL=llama3.2
CHATBOT_DEFAULT_PERSONALITY=default
CHATBOT_CORS_ORIGINS=http://localhost:3000

# API Keys (optional, required only for cloud providers)
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-...

# Ollama (default local provider)
OLLAMA_BASE_URL=http://localhost:11434

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
